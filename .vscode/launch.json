    "version": "0.2.0",
    "configurations": [
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug executable 'fhir-generate'",
            "cargo": {
                "args": [
                    "build",
                    "--bin=fhir-generate",
                    "--package=fhir-generate"
                ],
                "filter": {
                    "name": "fhir-generate",
                    "kind": "bin"
                }
            },
            "args": [
                "plant-uml",
                "-e",
                "./test_data/ep-ed/StructureDefinition-EHDSMedicationDispense.json",
                "./test_data/ep-ed/StructureDefinition-EHDSMedication.json ",
                "./test_data/ep-ed/StructureDefinition-EHDSDosaging.json",
                "./test_data/ep-ed/StructureDefinition-EHDSPatient.json",
                "./test_data/ep-ed/StructureDefinition-EHDSHealthProfessional.json",
                "./test_data/ep-ed/StructureDefinition-EHDSOrganization.json",
                "./test_data/ep-ed/StructureDefinition-EHDSDevice.json",
            ],
            "cwd": "${workspaceFolder}"
        },
        {
            "type": "lldb",
            "request": "launch",
            "name": "Debug unit tests in executable 'fhir-generate'",
            "cargo": {
                "args": [
                    "test",
                    "--no-run",
                    "--bin=fhir-generate",
                    "--package=fhir-generate"
                ],
                "filter": {
                    "name": "fhir-generate",
                    "kind": "bin"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}